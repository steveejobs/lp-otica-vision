NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_PROJECT_REF=
BOOTSTRAP_ADMIN_EMAIL=

# Google Analytics 4
# Publico: Measurement ID do fluxo Web (formato G-XXXXXXXXXX).
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-NCHZYFNGTJ

# Servidor: ID numerico da propriedade GA4; nao use ID da conta ou do fluxo.
GA_PROPERTY_ID=

# Servidor: campos client_email e private_key do JSON de uma conta de servico.
GA_CLIENT_EMAIL=
# Na Vercel, cole somente o valor de private_key. O app aceita quebras reais ou \n escapado.
GA_PRIVATE_KEY=

# Servidor: secret novo do Measurement Protocol. Nunca use um secret exposto.
GA_MEASUREMENT_API_SECRET=
